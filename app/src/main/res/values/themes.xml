<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Material3 深色主题: 深空蓝背景 + 荧光青强调 -->
    <style name="Theme.AimAssistant" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorPrimaryContainer">@color/bg_surface_variant</item>
        <item name="colorOnPrimaryContainer">@color/accent_primary</item>

        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/bg_primary</item>

        <item name="colorError">@color/accent_danger</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="materialCardViewStyle">@style/Widget.AimAssistant.CardView</item>
    </style>

    <!-- 卡片样式: 圆角 + 深色表面 -->
    <style name="Widget.AimAssistant.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">16dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- 文本样式 -->
    <style name="TextAppearance.AimAssistant.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AimAssistant.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AimAssistant.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.AimAssistant.Status" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- 按钮样式 -->
    <style name="Widget.AimAssistant.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
